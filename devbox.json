{
    "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
    "packages": [
      "ansible-doctor@8.3.1",
      "ansible-lint@25.8.2",
      "git@2.54.0",
      "glibcLocales@2.40-66",
      "go-task@3.48.0",
      "kind@0.31.0",
      "kubectl@1.36.1",
      "kubernetes-helm@4.2.0",
      "prek@0.3.11",
      "python313Packages.ansible@13.7.0",
      "python313Packages.kubernetes@35.0.0",
      "python313Packages.molecule@26.4.0",
      "python313Packages.molecule-plugins@25.8.12",
      "yamllint@1.37.1"
    ],
    "env": {
      "DEVBOX_NO_PROMPT": "1",
      "DEVBOX_VIRTUAL_ENV": "${DEVBOX_PROJECT_ROOT}/.devbox/virtenv"
    },
    "shell": {
      "init_hook": [
        "export ANSIBLE_HOME=${DEVBOX_VIRTUAL_ENV}/ansible;",
        "export ANSIBLE_GALAXY_ROLES_PATH=${DEVBOX_VIRTUAL_ENV}/ansible/roles;",
        "export ANSIBLE_GALAXY_COLLECTIONS_PATH=${DEVBOX_VIRTUAL_ENV}/ansible/collections;",
        "export ANSIBLE_COLLECTION_ROLES_PATH=${DEVBOX_PROJECT_ROOT}/roles;",
        "export ANSIBLE_ROLES_PATH=${ANSIBLE_GALAXY_ROLES_PATH}:${ANSIBLE_COLLECTION_ROLES_PATH};",
        "export ANSIBLE_COLLECTIONS_PATH=${ANSIBLE_GALAXY_COLLECTIONS_PATH};",
        "export HELM_REPOSITORY_CONFIG=${DEVBOX_VIRTUAL_ENV}/helm/repositories.yaml;",
        "export HELM_REPOSITORY_CACHE=${DEVBOX_VIRTUAL_ENV}/helm/cache;",
        "task prepare"
      ]
    }
  }
