remoteWrite: {{ victoriametrics_vmagent_remote_write | ansible.builtin.to_json }}

podAnnotations: {{ victoriametrics_vmagent_pod_annotations | ansible.builtin.to_json }}

{% if victoriametrics_vmagent_extra_args is defined %}
extraArgs:
  {{ victoriametrics_vmagent_extra_args | ansible.builtin.to_nice_yaml | indent(2) }}
{% endif %}

config:
  global:
    scrape_interval: "{{ victoriametrics_vmagent_config_scrape_interval }}"

{% if victoriametrics_vmagent_config_scrap_configs is defined %}
  scrape_configs: {{ victoriametrics_vmagent_config_scrap_configs | ansible.builtin.to_json }}
{% endif %}
